#!/usr/bin/env bash
# This script configures the /etc/hosts file to redirect specific hosts

# 1. Change localhost resolution from 127.0.0.1 to 127.0.0.2
# Using sed to find the line containing 127.0.0.1 and replace it with 127.0.0.2
sudo sed -i 's/127.0.0.1/127.0.0.2/g' /etc/hosts

# 2. Redirect facebook.com to 8.8.8.8
# Check if facebook.com entry already exists to avoid duplicates
if grep -q "facebook.com" /etc/hosts; then
    # If it exists, update the IP to 8.8.8.8
    sudo sed -i 's/.*facebook.com/8.8.8.8 facebook.com/' /etc/hosts
else
    # If it doesn't exist, append the new entry to the end of the file
    echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts
fi

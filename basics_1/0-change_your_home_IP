#!/usr/bin/env bash
# Configures /etc/hosts to resolve localhost to 127.0.0.2 and facebook.com to 8.8.8.8

# Use sed to modify the content and pipe it to sudo tee to overwrite the file
# This avoids the "Device or resource busy" error caused by sed -i
sed 's/127.0.0.1/127.0.0.2/' /etc/hosts | sudo tee /etc/hosts > /dev/null

# Add facebook.com resolution to 8.8.8.8
# We check if it exists to avoid multiple entries, then rewrite the file
if grep -q "facebook.com" /etc/hosts; then
    sed 's/.*facebook.com/8.8.8.8 facebook.com/' /etc/hosts | sudo tee /etc/hosts > /dev/null
else
    echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts > /dev/null
fi
